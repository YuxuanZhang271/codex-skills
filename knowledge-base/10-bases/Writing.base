filters:
  and:
    - 'file.ext == "md"'
    - 'file.inFolder("05-writing")'
    - 'type == "draft"'

formulas:
  days_until_due: 'if(due, (date(due) - today()).days, "")'

properties:
  status:
    displayName: "Status"
  target:
    displayName: "Target"
  due:
    displayName: "Due"
  formula.days_until_due:
    displayName: "Days Left"

views:
  - type: table
    name: "Active Writing"
    filters:
      and:
        - 'status != "submitted"'
        - 'status != "accepted"'
        - 'status != "archived"'
    order:
      - file.name
      - status
      - target
      - due
      - formula.days_until_due
      - next_action

  - type: table
    name: "All Writing"
    order:
      - file.name
      - status
      - target
      - due
      - updated
