filters:
  and:
    - 'file.ext == "md"'
    - 'file.inFolder("03-projects")'
    - 'type == "project"'

formulas:
  days_until_deadline: 'if(deadline, (date(deadline) - today()).days, "")'

properties:
  status:
    displayName: "Status"
  research_area:
    displayName: "Area"
  deadline:
    displayName: "Deadline"
  formula.days_until_deadline:
    displayName: "Days Left"

views:
  - type: table
    name: "Active Projects"
    filters:
      and:
        - 'status != "done"'
        - 'status != "archived"'
    order:
      - file.name
      - status
      - research_area
      - deadline
      - formula.days_until_deadline
      - next_action
    groupBy:
      property: status
      direction: ASC

  - type: table
    name: "All Projects"
    order:
      - file.name
      - status
      - research_area
      - deadline
      - updated
