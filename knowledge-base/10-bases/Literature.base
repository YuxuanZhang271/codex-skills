filters:
  and:
    - 'file.ext == "md"'
    - 'file.inFolder("01-literature")'
    - or:
        - 'type == "paper"'
        - 'type == "reading"'
        - 'type == "synthesis"'

formulas:
  year_label: 'if(year, year.toString(), "")'
  priority_label: 'if(priority == 1, "High", if(priority == 2, "Medium", if(priority == 3, "Low", "")))'

properties:
  title:
    displayName: "Title"
  authors:
    displayName: "Authors"
  venue:
    displayName: "Venue"
  year:
    displayName: "Year"
  status:
    displayName: "Status"
  research_area:
    displayName: "Area"
  priority:
    displayName: "Priority"
  formula.priority_label:
    displayName: "Priority Label"

views:
  - type: table
    name: "Reading Queue"
    filters:
      or:
        - 'status == "to-read"'
        - 'status == "reading"'
    order:
      - file.name
      - status
      - formula.priority_label
      - authors
      - year
      - venue
      - research_area
    groupBy:
      property: status
      direction: ASC

  - type: table
    name: "Literature Library"
    order:
      - file.name
      - status
      - authors
      - year
      - venue
      - research_area
      - rating
    groupBy:
      property: research_area
      direction: ASC
